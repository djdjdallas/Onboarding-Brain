{
  "name": "seo-page-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:templates": "node --env-file=.env.local scripts/seed-page-templates.mjs",
    "seed:templates:dry": "node scripts/seed-page-templates.mjs --dry-run",
    "seed:eligibility-types": "node --env-file=.env.local scripts/seed-eligibility-flag-types.mjs",
    "seed:cadence": "node --env-file=.env.local scripts/seed-cadence-rules.mjs",
    "seed:packages": "node --env-file=.env.local scripts/seed-package-tiers.mjs",
    "seed:subtasks": "node --env-file=.env.local scripts/seed-subtask-types.mjs",
    "seed:keywords": "node --env-file=.env.local scripts/seed-keywords.mjs",
    "seed:all": "npm run seed:eligibility-types && npm run seed:cadence && npm run seed:packages && npm run seed:subtasks && npm run seed:keywords",
    "migrate:v2": "node --env-file=.env.local scripts/migrate-v1-to-v2.mjs",
    "migrate:v2:dry": "node --env-file=.env.local scripts/migrate-v1-to-v2.mjs --dry-run",
    "cleanup:gate-keys": "node --env-file=.env.local scripts/cleanup-gate-keys.mjs",
    "cleanup:gate-keys:dry": "node --env-file=.env.local scripts/cleanup-gate-keys.mjs --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.1",
    "react-markdown": "^10.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.8.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4"
  }
}
